# NexusCode Environment Variables

# LLM Provider Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Band.ai
BAND_API_KEY=band_your-band-key

# Agent UUIDs (register at https://app.band.ai/agents)
NEXUS_PLANNER_AGENT_ID=your-planner-uuid
NEXUS_ARCHITECT_AGENT_ID=your-architect-uuid
NEXUS_DEVELOPER_AGENT_ID=your-developer-uuid
NEXUS_REVIEWER_AGENT_ID=your-reviewer-uuid
NEXUS_REDTEAMER_AGENT_ID=your-redteamer-uuid
NEXUS_VERIFIER_AGENT_ID=your-verifier-uuid
NEXUS_QA_AGENT_ID=your-qa-uuid
NEXUS_DEVOPS_AGENT_ID=your-devops-uuid
NEXUS_SCRIBE_AGENT_ID=your-scribe-uuid
NEXUS_ADJUDICATOR_AGENT_ID=your-adjudicator-uuid
NEXUS_HUMANGATE_AGENT_ID=your-humangate-uuid

# System Config
NEXUSCODE_PROJECT_NAME=nexuscode-project
NEXUSCODE_LOG_LEVEL=INFO
NEXUSCODE_MEMORY_PATH=.nexuscode/memory
NEXUSCODE_AUDIT_PATH=.nexuscode/audit
